<Window x:Class="JamLib.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JamLib - Keyboard Logger" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="JamLib - Keyboard Activity Monitor" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Parental Control System" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Control Panel -->
        <Border Grid.Row="1" Background="White" Padding="20" BorderThickness="0,1,0,1" BorderBrush="#ECF0F1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Name="StartButton" Click="StartButton_Click" 
                        Background="#27AE60" Foreground="White" 
                        Padding="15,10" FontSize="14" FontWeight="Bold"
                        Width="120">Start Logging</Button>
                
                <Button Name="StopButton" Click="StopButton_Click" 
                        Background="#E74C3C" Foreground="White" 
                        Padding="15,10" FontSize="14" FontWeight="Bold"
                        Width="120" IsEnabled="False">Stop Logging</Button>
                
                <Separator Width="1" Background="#ECF0F1" Margin="10,0"/>
                
                <Button Name="OpenLogFolderButton" Click="OpenLogFolder_Click" 
                        Background="#3498DB" Foreground="White" 
                        Padding="15,10" FontSize="14" FontWeight="Bold"
                        Width="150">Open Log Folder</Button>
                
                <Button Name="RefreshButton" Click="RefreshLogs_Click" 
                        Background="#9B59B6" Foreground="White" 
                        Padding="15,10" FontSize="14" FontWeight="Bold"
                        Width="120">Refresh Logs</Button>
            </StackPanel>
        </Border>

        <!-- Log Content Area -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Log Files List -->
            <Border Grid.Column="0" Background="White" BorderThickness="1" BorderBrush="#ECF0F1">
                <StackPanel>
                    <TextBlock Text="Log Files" FontSize="14" FontWeight="Bold" 
                               Padding="10" Background="#ECF0F1" BorderThickness="0,0,0,1" BorderBrush="#BDC3C7"/>
                    <ListBox Name="LogFilesList" ItemsSource="{Binding LogFiles}" 
                             SelectionChanged="LogFilesList_SelectionChanged"
                             Background="White" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Log Content Display -->
            <Border Grid.Column="1" Margin="10,0,0,0" Background="White" BorderThickness="1" BorderBrush="#ECF0F1">
                <StackPanel>
                    <TextBlock Text="Log Content" FontSize="14" FontWeight="Bold" 
                               Padding="10" Background="#ECF0F1" BorderThickness="0,0,0,1" BorderBrush="#BDC3C7"/>
                    <TextBox Name="LogContent" Background="#FAFAFA" 
                             Foreground="#333333" 
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="10"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="20" BorderThickness="0,1,0,0" BorderBrush="#34495E">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Name="StatusText" Text="Status: Ready" Foreground="#27AE60" FontWeight="Bold"/>
                <TextBlock Name="LogPathText" Text="" Foreground="#95A5A6" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>